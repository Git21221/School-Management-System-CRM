{
  "info": {
    "name": "School CRM API",
    "description": "TechAcademy / Institute CRM backend. Import with School-CRM-Local environment.\n\n1. Set adminPassword in environment\n2. Run Auth → Login (saves accessToken)\n3. Call other endpoints (Bearer token auto-attached)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "accessToken", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "auth": { "type": "noauth" },
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data?.accessToken) {",
                  "  pm.environment.set('accessToken', res.data.accessToken);",
                  "  pm.collectionVariables.set('accessToken', res.data.accessToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/auth/refresh",
            "description": "Requires refreshToken HttpOnly cookie from Login. Enable cookies in Postman settings."
          }
        },
        {
          "name": "Logout",
          "request": { "method": "POST", "url": "{{baseUrl}}/auth/logout" }
        },
        {
          "name": "Get Current User",
          "request": { "method": "GET", "url": "{{baseUrl}}/auth/me" }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"{{adminPassword}}\",\n  \"newPassword\": \"NewPassword123\"\n}"
            },
            "url": "{{baseUrl}}/auth/password"
          }
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        { "name": "KPI Stats", "request": { "method": "GET", "url": "{{baseUrl}}/dashboard/stats" } },
        { "name": "Enrollment Trend", "request": { "method": "GET", "url": "{{baseUrl}}/dashboard/enrollment-trend" } },
        { "name": "Fee Trend", "request": { "method": "GET", "url": "{{baseUrl}}/dashboard/fee-trend" } },
        { "name": "Today Classes", "request": { "method": "GET", "url": "{{baseUrl}}/dashboard/today-classes" } }
      ]
    },
    {
      "name": "Courses",
      "item": [
        { "name": "List Courses", "request": { "method": "GET", "url": "{{baseUrl}}/courses" } },
        { "name": "Get Course", "request": { "method": "GET", "url": "{{baseUrl}}/courses/CRS-001" } },
        {
          "name": "Create Course",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"CRS-010\",\n  \"name\": \"Python Basics\",\n  \"duration\": \"3 Months\",\n  \"fees\": 15000,\n  \"description\": \"Intro to Python\",\n  \"status\": \"Active\"\n}"
            },
            "url": "{{baseUrl}}/courses"
          }
        },
        {
          "name": "Update Course",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"fees\": 16000\n}" },
            "url": "{{baseUrl}}/courses/CRS-010"
          }
        },
        { "name": "Delete Course", "request": { "method": "DELETE", "url": "{{baseUrl}}/courses/CRS-010" } }
      ]
    },
    {
      "name": "Batches",
      "item": [
        { "name": "List Batches", "request": { "method": "GET", "url": "{{baseUrl}}/batches" } },
        { "name": "Get Batch", "request": { "method": "GET", "url": "{{baseUrl}}/batches/BAT-001" } },
        { "name": "Batch Students", "request": { "method": "GET", "url": "{{baseUrl}}/batches/BAT-001/students" } },
        {
          "name": "Create Batch",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"BAT-099\",\n  \"courseId\": \"CRS-001\",\n  \"name\": \"Evening Batch\",\n  \"timing\": \"Mon-Fri 6-9 PM\",\n  \"facultyId\": \"FAC-001\",\n  \"status\": \"Upcoming\",\n  \"startDate\": \"2025-01-01\",\n  \"endDate\": \"2025-06-30\"\n}"
            },
            "url": "{{baseUrl}}/batches"
          }
        },
        {
          "name": "Update Batch",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"Ongoing\"\n}" },
            "url": "{{baseUrl}}/batches/BAT-099"
          }
        },
        { "name": "Delete Batch", "request": { "method": "DELETE", "url": "{{baseUrl}}/batches/BAT-099" } }
      ]
    },
    {
      "name": "Students",
      "item": [
        {
          "name": "List Students",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/students?search=&course=&status=&page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["students"],
              "query": [
                { "key": "search", "value": "" },
                { "key": "course", "value": "" },
                { "key": "status", "value": "" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        { "name": "Get Student", "request": { "method": "GET", "url": "{{baseUrl}}/students/STU-001" } },
        {
          "name": "Create Student",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"STU-099\",\n  \"name\": \"New Student\",\n  \"phone\": \"9876543210\",\n  \"email\": \"new@email.com\",\n  \"courseId\": \"CRS-001\",\n  \"batchId\": \"BAT-001\",\n  \"guardian\": \"Parent Name\",\n  \"guardianPhone\": \"9876543200\",\n  \"address\": \"City\",\n  \"admissionDate\": \"2025-01-15\",\n  \"feesTotal\": 25000,\n  \"feesPaid\": 0,\n  \"status\": \"Active\",\n  \"dob\": \"2000-01-01\",\n  \"grade\": \"A\"\n}"
            },
            "url": "{{baseUrl}}/students"
          }
        },
        {
          "name": "Update Student",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"phone\": \"9999999999\"\n}" },
            "url": "{{baseUrl}}/students/STU-099"
          }
        },
        { "name": "Delete Student", "request": { "method": "DELETE", "url": "{{baseUrl}}/students/STU-099" } },
        {
          "name": "Upload Photo",
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [{ "key": "photo", "type": "file", "src": [] }]
            },
            "url": "{{baseUrl}}/students/STU-001/photo"
          }
        }
      ]
    },
    {
      "name": "Attendance",
      "item": [
        {
          "name": "Get Attendance",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/attendance?batchId=BAT-001&date=2024-03-10",
              "host": ["{{baseUrl}}"],
              "path": ["attendance"],
              "query": [
                { "key": "batchId", "value": "BAT-001" },
                { "key": "date", "value": "2024-03-10" }
              ]
            }
          }
        },
        {
          "name": "Save Attendance",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"batchId\": \"BAT-001\",\n  \"date\": \"2024-03-10\",\n  \"records\": [\n    { \"studentId\": \"STU-001\", \"status\": \"present\" },\n    { \"studentId\": \"STU-002\", \"status\": \"absent\" }\n  ]\n}"
            },
            "url": "{{baseUrl}}/attendance"
          }
        },
        {
          "name": "Monthly Report",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/attendance/report?batchId=BAT-001&month=3&year=2024",
              "host": ["{{baseUrl}}"],
              "path": ["attendance", "report"],
              "query": [
                { "key": "batchId", "value": "BAT-001" },
                { "key": "month", "value": "3" },
                { "key": "year", "value": "2024" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Fees",
      "item": [
        { "name": "Due Fees", "request": { "method": "GET", "url": "{{baseUrl}}/fees/due" } },
        { "name": "Payment History", "request": { "method": "GET", "url": "{{baseUrl}}/payments" } },
        { "name": "Get Receipt", "request": { "method": "GET", "url": "{{baseUrl}}/payments/RCP-2024-0892" } },
        {
          "name": "Collect Payment",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"studentId\": \"STU-001\",\n  \"amount\": 5000,\n  \"mode\": \"UPI\",\n  \"payDate\": \"2025-01-15\",\n  \"remarks\": \"Installment 1\"\n}"
            },
            "url": "{{baseUrl}}/payments"
          }
        },
        {
          "name": "Send Fee Reminders",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{}" },
            "url": "{{baseUrl}}/fees/reminders"
          }
        }
      ]
    },
    {
      "name": "Faculty",
      "item": [
        { "name": "List Faculty", "request": { "method": "GET", "url": "{{baseUrl}}/faculty" } },
        { "name": "Get Faculty", "request": { "method": "GET", "url": "{{baseUrl}}/faculty/FAC-001" } },
        {
          "name": "Create Faculty",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"FAC-099\",\n  \"name\": \"Jane Doe\",\n  \"subject\": \"Mathematics\",\n  \"phone\": \"9876543210\",\n  \"email\": \"jane@example.com\",\n  \"salary\": 40000,\n  \"experience\": \"3 Years\",\n  \"qualification\": \"M.Sc\"\n}"
            },
            "url": "{{baseUrl}}/faculty"
          }
        },
        {
          "name": "Update Faculty",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"salary\": 42000\n}" },
            "url": "{{baseUrl}}/faculty/FAC-099"
          }
        },
        { "name": "Delete Faculty", "request": { "method": "DELETE", "url": "{{baseUrl}}/faculty/FAC-099" } },
        {
          "name": "Mark Faculty Attendance",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"date\": \"2025-01-15\",\n  \"status\": \"present\"\n}"
            },
            "url": "{{baseUrl}}/faculty/FAC-001/attendance"
          }
        },
        { "name": "Salary Slip", "request": { "method": "GET", "url": "{{baseUrl}}/faculty/FAC-001/salary" } }
      ]
    },
    {
      "name": "Exams",
      "item": [
        { "name": "List Exams", "request": { "method": "GET", "url": "{{baseUrl}}/exams" } },
        { "name": "Get Exam", "request": { "method": "GET", "url": "{{baseUrl}}/exams/EXM-001" } },
        {
          "name": "Create Exam",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"EXM-099\",\n  \"title\": \"Mid Term\",\n  \"courseId\": \"CRS-001\",\n  \"batchId\": \"BAT-001\",\n  \"examDate\": \"2025-02-01\",\n  \"maxMarks\": 100,\n  \"status\": \"Upcoming\"\n}"
            },
            "url": "{{baseUrl}}/exams"
          }
        },
        {
          "name": "Update Exam",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"Completed\"\n}" },
            "url": "{{baseUrl}}/exams/EXM-099"
          }
        },
        { "name": "Delete Exam", "request": { "method": "DELETE", "url": "{{baseUrl}}/exams/EXM-099" } },
        { "name": "Get Marks", "request": { "method": "GET", "url": "{{baseUrl}}/exams/EXM-001/marks" } },
        {
          "name": "Save Marks",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"marks\": [\n    { \"studentId\": \"STU-001\", \"marks\": 85 },\n    { \"studentId\": \"STU-002\", \"marks\": 72 }\n  ]\n}"
            },
            "url": "{{baseUrl}}/exams/EXM-001/marks"
          }
        },
        { "name": "Get Results", "request": { "method": "GET", "url": "{{baseUrl}}/exams/EXM-001/results" } }
      ]
    },
    {
      "name": "Certificates",
      "item": [
        { "name": "List Certificates", "request": { "method": "GET", "url": "{{baseUrl}}/certificates" } },
        {
          "name": "Issue Certificate",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"studentId\": \"STU-007\",\n  \"courseId\": \"CRS-003\",\n  \"grade\": \"A\",\n  \"issueDate\": \"2025-01-15\",\n  \"authorisedBy\": \"Director\"\n}"
            },
            "url": "{{baseUrl}}/certificates"
          }
        },
        { "name": "Get Certificate", "request": { "method": "GET", "url": "{{baseUrl}}/certificates/CERT-2024-0001" } }
      ]
    },
    {
      "name": "Reports",
      "item": [
        { "name": "Students Report", "request": { "method": "GET", "url": "{{baseUrl}}/reports/students" } },
        { "name": "Admissions Report", "request": { "method": "GET", "url": "{{baseUrl}}/reports/admissions" } },
        { "name": "Fees Report", "request": { "method": "GET", "url": "{{baseUrl}}/reports/fees" } },
        { "name": "Due Fees Report", "request": { "method": "GET", "url": "{{baseUrl}}/reports/fees/due" } },
        { "name": "Attendance Report", "request": { "method": "GET", "url": "{{baseUrl}}/reports/attendance" } },
        { "name": "Faculty Report", "request": { "method": "GET", "url": "{{baseUrl}}/reports/faculty" } },
        { "name": "Export CSV", "request": { "method": "GET", "url": "{{baseUrl}}/reports/students/export" } }
      ]
    },
    {
      "name": "Notifications",
      "item": [
        { "name": "List Notifications", "request": { "method": "GET", "url": "{{baseUrl}}/notifications" } },
        { "name": "Mark Read", "request": { "method": "PATCH", "url": "{{baseUrl}}/notifications/1/read" } },
        { "name": "Mark All Read", "request": { "method": "PATCH", "url": "{{baseUrl}}/notifications/read-all" } },
        { "name": "Delete Notification", "request": { "method": "DELETE", "url": "{{baseUrl}}/notifications/1" } }
      ]
    },
    {
      "name": "Settings",
      "item": [
        { "name": "Get Institute", "request": { "method": "GET", "url": "{{baseUrl}}/settings/institute" } },
        {
          "name": "Update Institute",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Triton Institute\",\n  \"phone\": \"+91-9876543210\",\n  \"email\": \"info@triton.local\",\n  \"address\": \"Your address\",\n  \"registrationNo\": \"REG-001\",\n  \"academicYear\": \"2025-26\"\n}"
            },
            "url": "{{baseUrl}}/settings/institute"
          }
        },
        { "name": "Get Receipt Config", "request": { "method": "GET", "url": "{{baseUrl}}/settings/receipt" } },
        {
          "name": "Update Receipt Config",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"prefix\": \"RCP-2025-\",\n  \"startingNumber\": \"0001\",\n  \"footerText\": \"Thank you.\",\n  \"showLogo\": \"Yes\",\n  \"printFormat\": \"A4\"\n}"
            },
            "url": "{{baseUrl}}/settings/receipt"
          }
        },
        { "name": "Get Certificate Config", "request": { "method": "GET", "url": "{{baseUrl}}/settings/certificate" } },
        {
          "name": "Update Certificate Config",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"prefix\": \"CERT-2025-\",\n  \"authorisedBy\": \"Director\",\n  \"bodyText\": \"This certifies completion of [Course Name].\"\n}"
            },
            "url": "{{baseUrl}}/settings/certificate"
          }
        }
      ]
    }
  ]
}

# Backend — copy to backend/.env and customize for YOUR institute
# Run: npm run db:setup  (interactive — asks institute name, admin password, etc.)

# ─────────────────────────────────────────────────────────────────
# Institute (you define these — not hardcoded)
# ─────────────────────────────────────────────────────────────────
# Display name shown in the app and institute_settings table
INSTITUTE_NAME=My Institute

# MySQL schema name (optional — defaults to a slug from INSTITUTE_NAME, e.g. "Triton Academy" → triton_academy)
# Use your existing Workbench schema: DATABASE_NAME=triton
# DATABASE_NAME=triton

# First admin account (created by db:setup)
ADMIN_NAME=Administrator
ADMIN_EMAIL=admin@myinstitute.local
ADMIN_PASSWORD=choose_a_strong_password_min_8_chars
# ADMIN_PHONE=+91 98765 43210

# Optional sample courses/students after setup (true | false)
# SEED_SAMPLE_DATA=true

# ─────────────────────────────────────────────────────────────────
# Database setup (one-time: npm run db:setup)
# ─────────────────────────────────────────────────────────────────
# MySQL root password — only needed during db:setup
# MYSQL_ROOT_PASSWORD=your_mysql_root_password

# Filled automatically by db:setup (or set manually if you configure MySQL yourself):
# DATABASE_URL=mysql://DB_USER:DB_PASSWORD@localhost:3306/DATABASE_NAME
# DB_USER=
# DB_PASSWORD=

DATABASE_URL=mysql://root:CHANGE_ME@localhost:3306/triton
DATABASE_POOL_MAX=10

# ─────────────────────────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─────────────────────────────────────────────────────────────────
# JWT — db:setup generates these if missing (or: openssl rand -hex 64)
# ─────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=GENERATE_WITH_openssl_rand_hex_64
JWT_REFRESH_SECRET=GENERATE_SEPARATE_SECRET_WITH_openssl_rand_hex_64
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─────────────────────────────────────────────────────────────────
# Security
# ─────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_AUTH_MAX=5
RATE_LIMIT_API_MAX=120

# ─────────────────────────────────────────────────────────────────
# File uploads
# ─────────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=5
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,application/pdf

# ─────────────────────────────────────────────────────────────────
# Email (optional)
# ─────────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="School CRM" <no-reply@yourdomain.com>

LOG_LEVEL=info
